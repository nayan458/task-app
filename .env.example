NODE_ENV=development

# API Gateway
GATEWAY_HTTP_PORT=3000

# gRPC service URLs (host:port the services bind to and gateway connects to)
AUTH_GRPC_URL=0.0.0.0:50051
TASK_GRPC_URL=0.0.0.0:50052

# MongoDB
MONGO_URI=mongodb://localhost:27017/taskflow

# JWT (must be at least 32 chars)
JWT_SECRET=replace-me-with-a-strong-random-secret-of-32+chars
JWT_EXPIRES_IN=7d

# Throttling (window in seconds, max requests per window per IP)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=info
