{
  "info": {
    "name": "TaskFlow API",
    "_postman_id": "b7c8a9d0-1e2f-4abc-9def-0123456789ab",
    "description": "Postman collection for the TaskFlow API gateway. Run requests in order — register/login populate `accessToken` and task creation stores `taskId` for follow-up requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('uniqueEmail')) {",
          "  const stamp = Date.now();",
          "  pm.collectionVariables.set('uniqueEmail', `john+${stamp}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "uniqueEmail", "value": "", "type": "string" },
    { "key": "password", "value": "StrongPass123!", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"{{uniqueEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "pm.test('envelope success=true', () => pm.expect(json.success).to.eql(true));",
                  "pm.test('returns token', () => pm.expect(json.data.token).to.be.a('string').and.not.empty);",
                  "pm.test('returns user with id and email', () => {",
                  "  pm.expect(json.data.user.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.user.email).to.eql(pm.collectionVariables.get('uniqueEmail'));",
                  "});",
                  "pm.test('password is not echoed back', () => pm.expect(JSON.stringify(json.data.user)).to.not.include('password'));",
                  "",
                  "pm.collectionVariables.set('accessToken', json.data.token);",
                  "pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — duplicate email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
